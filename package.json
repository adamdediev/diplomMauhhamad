{
  "name": "solid-nextjs",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:generate": "ts-node scripts/ai-test-generator.ts generate",
    "test:update": "ts-node scripts/ai-test-generator.ts update",
    "test:analyze": "ts-node scripts/ai-test-generator.ts analyze",
    "test:all": "npm run test:ci && npm run test:e2e",
    "playwright:install": "playwright install"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "framer-motion": "^12.0.6",
    "next": "15.1.6",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hot-toast": "^2.4.1",
    "swiper": "^9.3.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@playwright/test": "^1.53.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.8.9",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0",
    "msw": "^2.10.2",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
